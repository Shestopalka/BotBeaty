# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Локальна авторизація (DEV ONLY) ──────────────────────────────────────────
# Дозволяє обходити Telegram-перевірку, коли немає X-Telegram-Init-Data.
# Має ефект ЛИШЕ коли NODE_ENV != production. У проді ігнорується завжди.
# Без цього прапорця локальні запити без initData повертатимуть 401.
ALLOW_DEV_AUTH_BYPASS=false
# Telegram ID майстра, від імені якого виконуються dev-запити (коли bypass=true)
DEV_TELEGRAM_ID=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=beatybot
DATABASE_PASSWORD=beatybot_secret
DATABASE_NAME=beatybot_db
DATABASE_URL=postgresql://beatybot:beatybot_secret@localhost:5432/beatybot_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Telegram ────────────────────────────────────────────────────────────────
# Головний бот платформи (для реєстрації майстрів)
PLATFORM_BOT_TOKEN=your_platform_bot_token_here

# Telegram Payments провайдер (Stripe test)
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token_here

# Webhook URL (ngrok для dev, або домен для prod)
WEBHOOK_BASE_URL=

# ─── Mini App ────────────────────────────────────────────────────────────────
MINI_APP_URL=https://your-mini-app-domain.com

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_very_long_secret
JWT_EXPIRES_IN=7d

# ─── S3 Backup ───────────────────────────────────────────────────────────────
S3_BUCKET=beatybot-backups
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
