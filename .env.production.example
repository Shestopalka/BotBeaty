# ─────────────────────────────────────────────────────────────────────────────
# Змінні середовища для ПРОДАКШЕНУ (Railway, один сервіс).
# У Railway додаються у вкладці Variables сервісу. Значення з ${{...}} —
# це посилання Railway на плагіни Postgres/Redis (вставляй саме так).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
# PORT Railway задає автоматично — НЕ хардкодь.

# ─── Database (Postgres-плагін) ──────────────────────────────────────────────
# Внутрішнє підключення Railway, SSL не потрібен.
DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_SSL=false

# ─── Redis (Redis-плагін) ────────────────────────────────────────────────────
REDIS_URL=${{Redis.REDIS_URL}}

# ─── Telegram ────────────────────────────────────────────────────────────────
PLATFORM_BOT_TOKEN=токен_платформного_бота_від_BotFather
# Необовʼязково (для Telegram Payments):
PAYMENT_PROVIDER_TOKEN=

# ─── Публічний домен сервісу ─────────────────────────────────────────────────
# Заповнюється ПІСЛЯ того, як Railway видасть домен (Settings → Networking →
# Generate Domain). Обидві змінні = той самий https-домен, потім Redeploy.
MINI_APP_URL=https://ТВІЙ-СЕРВІС.up.railway.app
WEBHOOK_BASE_URL=https://ТВІЙ-СЕРВІС.up.railway.app

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=згенеруй_довгий_випадковий_рядок_мін_32_символи
JWT_EXPIRES_IN=7d

# ─── ВАЖЛИВО ─────────────────────────────────────────────────────────────────
# ALLOW_DEV_AUTH_BYPASS у проді НЕ став (у production воно ігнорується завжди).
